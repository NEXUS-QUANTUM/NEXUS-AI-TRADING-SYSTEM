DEPLOYMENT_SEED_DATA=false

# ============================================
# KUBERNETES
# ============================================
KUBERNETES_ENABLED=false
KUBERNETES_NAMESPACE=nexus
KUBERNETES_CONFIG_PATH=~/.kube/config
KUBERNETES_CONTEXT=docker-desktop

# ============================================
# AWS
# ============================================
AWS_ENABLED=false
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=nexus-ai-data
AWS_S3_ENDPOINT=
AWS_S3_PATH_STYLE=false

# ============================================
# GCP
# ============================================
GCP_ENABLED=false
GCP_PROJECT_ID=your_gcp_project_id_here
GCP_CREDENTIALS_PATH=./gcp-credentials.json
GCP_STORAGE_BUCKET=nexus-ai-data

# ============================================
# AZURE
# ============================================
AZURE_ENABLED=false
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string_here
AZURE_STORAGE_CONTAINER=nexus-ai-data

# ============================================
# VAULT (Secret Management)
# ============================================
VAULT_ENABLED=false
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=your_vault_token_here
VAULT_PATH=secret/nexus

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_TRADING_ENABLED=true
FEATURE_PAPER_TRADING_ENABLED=true
FEATURE_LIVE_TRADING_ENABLED=false
FEATURE_BACKTESTING_ENABLED=true
FEATURE_SENTIMENT_ANALYSIS_ENABLED=true
FEATURE_SOCIAL_AUTH_ENABLED=true
FEATURE_2FA_ENABLED=true
FEATURE_CHAT_ENABLED=true
FEATURE_SUPPORT_ENABLED=true
FEATURE_SUBSCRIPTIONS_ENABLED=true
FEATURE_PAYMENTS_ENABLED=true
FEATURE_AI_PREDICTIONS_ENABLED=true
FEATURE_AI_TRAINING_ENABLED=true
FEATURE_MONITORING_ENABLED=true
FEATURE_REFERRAL_ENABLED=true
FEATURE_COMMUNITY_ENABLED=true
FEATURE_KNOWLEDGE_BASE_ENABLED=true

# ============================================
# BETA / EXPERIMENTAL
# ============================================
BETA_ENABLED=false
BETA_FEATURES=multi_agent_ai,quantum_computing,defi_integration
BETA_USERS=

# ============================================
# PERFORMANCE
# ============================================
PERFORMANCE_OPTIMIZATION_ENABLED=true
PERFORMANCE_CACHE_ENABLED=true
PERFORMANCE_QUERY_OPTIMIZATION=true
PERFORMANCE_BATCH_PROCESSING=true
PERFORMANCE_ASYNC_ENABLED=true

# ============================================
# MAINTENANCE
# ============================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System is under maintenance. Please come back later.
MAINTENANCE_ALLOWED_IPS=127.0.0.1

# ============================================
# NEXUS SPECIFIC
# ============================================
NEXUS_VERSION=1.0.0
NEXUS_BUILD=2026.01
NEXUS_COPYRIGHT="Copyright © 2026 NEXUS QUANTUM LTD"
NEXUS_CEO="Dr X... - Majority Shareholder"
NEXUS_ENVIRONMENT=development
NEXUS_SECRET_KEY=change_this_in_production_use_secrets_token_urlsafe_32

# ============================================
# REFERRAL SYSTEM
# ============================================
REFERRAL_ENABLED=true
REFERRAL_REWARD_AMOUNT=10
REFERRAL_REWARD_CURRENCY=USD
REFERRAL_MAX_REWARDS=100
REFERRAL_COOLDOWN_DAYS=30

# ============================================
# COMMUNITY
# ============================================
COMMUNITY_ENABLED=true
COMMUNITY_MODERATION_ENABLED=true
COMMUNITY_MAX_POSTS_PER_DAY=10
COMMUNITY_MAX_COMMENTS_PER_DAY=50

# ============================================
# KNOWLEDGE BASE
# ============================================
KNOWLEDGE_BASE_ENABLED=true
KNOWLEDGE_BASE_ARTICLES_PER_PAGE=20
KNOWLEDGE_BASE_SEARCH_ENABLED=true

# ============================================
# COMPLIANCE
# ============================================
COMPLIANCE_KYC_ENABLED=true
COMPLIANCE_AML_ENABLED=true
COMPLIANCE_TRAVEL_RULE_ENABLED=false
COMPLIANCE_REPORTING_ENABLED=true

# ============================================
# INTERNATIONALIZATION
# ============================================
I18N_ENABLED=true
I18N_DEFAULT_LOCALE=en
I18N_SUPPORTED_LOCALES=en,fr,es,de,zh,ja
I18N_FALLBACK_LOCALE=en

# ============================================
# ANALYTICS
# ============================================
ANALYTICS_ENABLED=true
ANALYTICS_GOOGLE_UA=UA-XXXXXXXXX-X
ANALYTICS_MIXPANEL_TOKEN=your_mixpanel_token_here
ANALYTICS_SEGMENT_WRITE_KEY=your_segment_write_key_here

# ============================================
# END OF FILE
# ============================================
