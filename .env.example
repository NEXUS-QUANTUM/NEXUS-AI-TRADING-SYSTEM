OANDA_URL=https://api-fxpractice.oanda.com
OANDA_WS_URL=wss://stream-fxpractice.oanda.com/v3/accounts
OANDA_TIMEOUT=30

# ============================================
# TRADING
# ============================================
TRADING_ENABLED=true
TRADING_MODE=paper
TRADING_MAX_POSITIONS=10
TRADING_MAX_TRADES_PER_DAY=100
TRADING_RISK_PER_TRADE=0.02
TRADING_MAX_DRAWDOWN=0.20
TRADING_STOP_LOSS_DEFAULT=0.02
TRADING_TAKE_PROFIT_DEFAULT=0.06
TRADING_TRAILING_STOP_DEFAULT=0.015
TRADING_MIN_ORDER_SIZE=10
TRADING_MAX_ORDER_SIZE=10000
TRADING_ORDER_TIMEOUT=30
TRADING_SLIPPAGE_TOLERANCE=0.001
TRADING_FEE_MAKER=0.001
TRADING_FEE_TAKER=0.001
TRADING_LEVERAGE_MAX=3
TRADING_MARGIN_CALL=0.8
TRADING_LIQUIDATION=0.5
TRADING_EMERGENCY_STOP=true
TRADING_PAUSE_ON_DRAWDOWN=true

# ============================================
# RISK MANAGEMENT
# ============================================
RISK_ENABLED=true
RISK_MAX_EXPOSURE=0.30
RISK_MAX_POSITION_SIZE=0.10
RISK_MAX_DAILY_LOSS=0.05
RISK_MAX_WEEKLY_LOSS=0.10
RISK_MAX_MONTHLY_LOSS=0.15
RISK_MAX_CORRELATION=0.70
RISK_VAR_CONFIDENCE=0.95
RISK_VAR_HORIZON=1
RISK_MAX_SHARPE=0.5
RISK_MAX_SORTINO=0.3
RISK_CIRCUIT_BREAKER_ENABLED=true
RISK_CIRCUIT_BREAKER_THRESHOLD=0.10
RISK_CIRCUIT_BREAKER_COOLDOWN=3600
RISK_EMERGENCY_SHUTDOWN=true
RISK_SAFE_MODE=true

