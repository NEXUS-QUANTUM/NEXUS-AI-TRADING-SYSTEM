# ============================================
IB_ENABLED=false
IB_ACCOUNT_ID=your_ib_account_id_here
IB_ENVIRONMENT=paper
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1
IB_TIMEOUT=30

