BYBIT_FUTURES_WS_URL=wss://stream.bybit.com/v5/public/linear
BYBIT_RECV_WINDOW=5000
BYBIT_TIMEOUT=30

# ============================================
# BROKER - KRAKEN
# ============================================
KRAKEN_ENABLED=false
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here
