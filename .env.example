AI_OPTIMIZER=adam
AI_LOSS_FUNCTION=mse
AI_ENSEMBLE_SIZE=5
AI_PREDICTION_THRESHOLD=0.6
AI_CONFIDENCE_MIN=0.5
AI_RETRAIN_INTERVAL=86400

