# AI / ML
# ============================================
AI_ENABLED=true
AI_MODEL_PATH=./data/models
AI_CACHE_PATH=./data/cache
AI_USE_GPU=true
AI_CUDA_DEVICE=0
AI_BATCH_SIZE=64
AI_EPOCHS=100
