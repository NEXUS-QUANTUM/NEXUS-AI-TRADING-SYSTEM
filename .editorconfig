# ============================================
[ROADMAP.md]
indent_size = 2
indent_style = space
max_line_length = 120

# ============================================
# README
# ============================================
[README.md]
indent_size = 2
indent_style = space
max_line_length = 120

# ============================================
# DOCKER COMPOSE
# ============================================
[docker-compose*.yml]
indent_size = 2
indent_style = space

# ============================================
# GITHUB ACTIONS
# ============================================
[.github/workflows/*.yml]
