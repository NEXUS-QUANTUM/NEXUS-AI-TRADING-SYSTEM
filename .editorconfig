indent_style = space

# ============================================
# VSCODE
# ============================================
[.vscode/*.json]
indent_size = 2
indent_style = space

# ============================================
# PRE-COMMIT
# ============================================
[.pre-commit-config.yaml]
indent_size = 2
indent_style = space

# ============================================
# RUFF
# ============================================
[ruff.toml]
indent_size = 2
indent_style = space

# ============================================
# BLACK
# ============================================
[pyproject.toml]
indent_size = 2
indent_style = space

# ============================================
# MYPY
# ============================================
[mypy.ini]
indent_size = 2
indent_style = space

# ============================================
# FLAKE8
# ============================================
[.flake8]
indent_size = 2
indent_style = space

# ============================================
# ISORT
# ============================================
[.isort.cfg]
indent_size = 2
indent_style = space

# ============================================
# PYTEST
# ============================================
[pytest.ini]
indent_size = 2
indent_style = space

# ============================================
# BANDIT
# ============================================
[.bandit]
indent_size = 2
indent_style = space

# ============================================
