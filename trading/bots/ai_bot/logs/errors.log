# FONCTIONS DE GESTION DES ERREURS
# ============================================================

def write_example_errors(filepath: str = "trading/bots/ai_bot/logs/errors.log") -> None:
    """
    Écrit les erreurs d'exemple dans un fichier.
    
    Args:
        filepath: Chemin du fichier d'erreurs.
    """
    import os
    
    try:
        # Création du répertoire si nécessaire
        os.makedirs(os.path.dirname(filepath), exist_ok=True)
        
        with open(filepath, 'w', encoding='utf-8') as f:
            for error in EXAMPLE_ERRORS:
                f.write(json.dumps(error) + '\n')
        
        print(f"✅ Erreurs écrites dans {filepath}")
        
    except Exception as e:
        print(f"❌ Erreur d'écriture: {e}")


def read_errors(
    filepath: str = "trading/bots/ai_bot/logs/errors.log",
    level: Optional[str] = None,
    module: Optional[str] = None,
    error_type: Optional[str] = None,
    limit: int = 100
) -> List[Dict[str, Any]]:
    """
    Lit les erreurs depuis un fichier.
    
    Args:
        filepath: Chemin du fichier d'erreurs.
        level: Niveau d'erreur.
        module: Module.
        error_type: Type d'erreur.
        limit: Nombre maximum d'erreurs.
        
    Returns:
        Liste des erreurs.
    """
    errors = []
    
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            for line in f:
                try:
                    error = json.loads(line.strip())
                    errors.append(error)
                except json.JSONDecodeError:
                    continue
        
        # Filtrage
        if level:
            errors = [e for e in errors if e.get('level') == level]
        
        if module:
            errors = [e for e in errors if e.get('module') == module]
        
        if error_type:
            errors = [e for e in errors if e.get('error', {}).get('type') == error_type]
        
        # Tri par timestamp (plus récent en premier)
        errors.sort(key=lambda x: x.get('timestamp', ''), reverse=True)
        
        return errors[:limit]
        
    except FileNotFoundError:
        print(f"⚠️ Fichier d'erreurs non trouvé: {filepath}")
        return []
    except Exception as e:
        print(f"❌ Erreur de lecture: {e}")
        return []


def get_error_stats(
    filepath: str = "trading/bots/ai_bot/logs/errors.log"
) -> Dict[str, Any]:
    """
    Retourne les statistiques des erreurs.
    
    Args:
        filepath: Chemin du fichier d'erreurs.
        
    Returns:
        Statistiques des erreurs.
    """
    errors = read_errors(filepath, limit=10000)
    
    if not errors:
        return {'total': 0}
    
    stats = {
        'total': len(errors),
        'by_level': {},
        'by_module': {},
        'by_type': {},
        'by_resolution': {},
        'first_error': errors[-1].get('timestamp') if errors else None,
        'last_error': errors[0].get('timestamp') if errors else None
    }
    
    for error in errors:
        level = error.get('level', 'UNKNOWN')
        module = error.get('module', 'UNKNOWN')
        error_type = error.get('error', {}).get('type', 'UNKNOWN')
        resolution = error.get('resolution', 'UNKNOWN')
        
        stats['by_level'][level] = stats['by_level'].get(level, 0) + 1
        stats['by_module'][module] = stats['by_module'].get(module, 0) + 1
        stats['by_type'][error_type] = stats['by_type'].get(error_type, 0) + 1
        stats['by_resolution'][resolution] = stats['by_resolution'].get(resolution, 0) + 1
    
    return stats


def get_error_by_resolution(
    filepath: str = "trading/bots/ai_bot/logs/errors.log"
) -> Dict[str, List[Dict[str, Any]]]:
    """
    Groupe les erreurs par résolution.
    
    Args:
        filepath: Chemin du fichier d'erreurs.
        
    Returns:
        Dictionnaire des erreurs groupées par résolution.
    """
    errors = read_errors(filepath, limit=10000)
    
    grouped = {}
    
    for error in errors:
        resolution = error.get('resolution', 'UNKNOWN')
        if resolution not in grouped:
            grouped[resolution] = []
        grouped[resolution].append(error)
    
    return grouped


def get_most_common_errors(
    filepath: str = "trading/bots/ai_bot/logs/errors.log",
    n: int = 5
) -> List[Dict[str, Any]]:
    """
    Retourne les erreurs les plus fréquentes.
    
    Args:
        filepath: Chemin du fichier d'erreurs.
        n: Nombre d'erreurs.
        
    Returns:
        Liste des erreurs les plus fréquentes.
    """
    errors = read_errors(filepath, limit=10000)
    
    if not errors:
        return []
    
    # Compter les occurrences
    error_counts = {}
    for error in errors:
        key = error.get('error', {}).get('type', 'UNKNOWN')
        if key not in error_counts:
            error_counts[key] = {'count': 0, 'example': error}
        error_counts[key]['count'] += 1
    
    # Trier par fréquence
    sorted_errors = sorted(error_counts.items(), key=lambda x: x[1]['count'], reverse=True)
    
    return [{'type': k, 'count': v['count'], 'example': v['example']} for k, v in sorted_errors[:n]]


