        print(f"[{error.get('timestamp')}] {error.get('level')} - {error.get('message')}")
        print(f"  Type: {error.get('error', {}).get('type', 'UNKNOWN')}")
        print(f"  Module: {error.get('module', 'UNKNOWN')}")
        print(f"  Résolution: {error.get('resolution', 'UNKNOWN')}")
    
    # Statistiques
    print("\n📊 Statistiques des erreurs:")
    stats = get_error_stats()
    print(f"Total erreurs: {stats.get('total', 0)}")
    print(f"Par niveau: {stats.get('by_level', {})}")
    print(f"Par module: {stats.get('by_module', {})}")
    print(f"Par type: {stats.get('by_type', {})}")
    
    # Erreurs les plus fréquentes
    print("\n🔝 Erreurs les plus fréquentes:")
    common = get_most_common_errors(n=3)
    for item in common:
        print(f"  {item['type']}: {item['count']} occurrences")

