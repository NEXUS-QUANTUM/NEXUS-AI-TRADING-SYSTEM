# ============================================================
# FONCTIONS DE GESTION DES PERFORMANCES
# ============================================================

def write_example_performance(filepath: str = "trading/bots/ai_bot/logs/performance.log") -> None:
    """
    Écrit les performances d'exemple dans un fichier.
    
    Args:
        filepath: Chemin du fichier de performances.
    """
    import os
    
    try:
        # Création du répertoire si nécessaire
        os.makedirs(os.path.dirname(filepath), exist_ok=True)
        
        with open(filepath, 'w', encoding='utf-8') as f:
            for perf in EXAMPLE_PERFORMANCE_LOGS:
                f.write(json.dumps(perf) + '\n')
        
        print(f"✅ Performances écrites dans {filepath}")
        
    except Exception as e:
        print(f"❌ Erreur d'écriture: {e}")


def read_performance(
    filepath: str = "trading/bots/ai_bot/logs/performance.log",
    perf_type: Optional[str] = None,
    start_time: Optional[datetime] = None,
    end_time: Optional[datetime] = None,
    limit: int = 100
) -> List[Dict[str, Any]]:
    """
    Lit les performances depuis un fichier.
    
    Args:
        filepath: Chemin du fichier de performances.
        perf_type: Type de performance.
        start_time: Heure de début.
        end_time: Heure de fin.
        limit: Nombre maximum d'entrées.
        
    Returns:
        Liste des performances.
    """
    performances = []
    
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            for line in f:
                try:
                    perf = json.loads(line.strip())
                    performances.append(perf)
                except json.JSONDecodeError:
                    continue
        
        # Filtrage
        if perf_type:
            performances = [p for p in performances if p.get('type') == perf_type]
        
        if start_time:
            performances = [p for p in performances if datetime.fromisoformat(p.get('timestamp', '')) >= start_time]
        
        if end_time:
            performances = [p for p in performances if datetime.fromisoformat(p.get('timestamp', '')) <= end_time]
        
        # Tri par timestamp (plus récent en premier)
        performances.sort(key=lambda x: x.get('timestamp', ''), reverse=True)
        
        return performances[:limit]
        
    except FileNotFoundError:
        print(f"⚠️ Fichier de performances non trouvé: {filepath}")
        return []
    except Exception as e:
        print(f"❌ Erreur de lecture: {e}")
        return []


def get_performance_stats(
    filepath: str = "trading/bots/ai_bot/logs/performance.log"
) -> Dict[str, Any]:
    """
    Retourne les statistiques des performances.
    
    Args:
        filepath: Chemin du fichier de performances.
        
    Returns:
        Statistiques des performances.
    """
    performances = read_performance(filepath, limit=10000)
    
    if not performances:
        return {'total': 0}
    
    stats = {
        'total': len(performances),
        'by_type': {},
        'time_range': {
            'first': performances[-1].get('timestamp') if performances else None,
            'last': performances[0].get('timestamp') if performances else None
        }
    }
    
    for perf in performances:
        perf_type = perf.get('type', 'UNKNOWN')
        stats['by_type'][perf_type] = stats['by_type'].get(perf_type, 0) + 1
    
    return stats


def get_performance_trend(
    filepath: str = "trading/bots/ai_bot/logs/performance.log",
    metric: str = "total_pnl",
    period: str = "daily"
) -> List[Dict[str, Any]]:
    """
    Retourne la tendance d'une métrique de performance.
    
    Args:
        filepath: Chemin du fichier de performances.
        metric: Métrique à analyser.
        period: Période ('daily', 'hourly').
        
    Returns:
        Liste des tendances.
    """
    if period == "daily":
        perf_type = "daily_performance"
    else:
        perf_type = "hourly_performance"
    
    performances = read_performance(
        filepath,
        perf_type=perf_type,
        limit=1000
    )
    
    trend = []
    for perf in performances:
        metrics = perf.get('metrics', {})
        if metric in metrics:
            trend.append({
                'timestamp': perf.get('timestamp'),
                'value': metrics[metric],
                'date': perf.get('date') or perf.get('timestamp')[:10]
            })
    
    return sorted(trend, key=lambda x: x['timestamp'])


def get_best_performance(
    filepath: str = "trading/bots/ai_bot/logs/performance.log",
    metric: str = "total_pnl",
    period: str = "daily"
) -> Optional[Dict[str, Any]]:
    """
    Retourne la meilleure performance.
    
    Args:
        filepath: Chemin du fichier de performances.
        metric: Métrique à analyser.
        period: Période ('daily', 'hourly').
        
    Returns:
        Meilleure performance.
    """
    trend = get_performance_trend(filepath, metric, period)
    
    if not trend:
        return None
    
    return max(trend, key=lambda x: x['value'])


def get_worst_performance(
    filepath: str = "trading/bots/ai_bot/logs/performance.log",
    metric: str = "total_pnl",
    period: str = "daily"
) -> Optional[Dict[str, Any]]:
    """
    Retourne la pire performance.
    
    Args:
        filepath: Chemin du fichier de performances.
        metric: Métrique à analyser.
        period: Période ('daily', 'hourly').
        
    Returns:
        Pire performance.
    """
    trend = get_performance_trend(filepath, metric, period)
    
    if not trend:
        return None
    
    return min(trend, key=lambda x: x['value'])


