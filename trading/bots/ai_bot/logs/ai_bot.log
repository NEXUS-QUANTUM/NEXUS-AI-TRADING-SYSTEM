# ============================================================
# FONCTIONS DE GESTION DES LOGS
# ============================================================

def write_example_logs(filepath: str = "trading/bots/ai_bot/logs/ai_bot.log") -> None:
    """
    Écrit les logs d'exemple dans un fichier.
    
    Args:
        filepath: Chemin du fichier de logs.
    """
    import os
    
    try:
        # Création du répertoire si nécessaire
        os.makedirs(os.path.dirname(filepath), exist_ok=True)
        
        with open(filepath, 'w', encoding='utf-8') as f:
            for log in EXAMPLE_LOGS:
                f.write(json.dumps(log) + '\n')
        
        print(f"✅ Logs écrits dans {filepath}")
        
    except Exception as e:
        print(f"❌ Erreur d'écriture des logs: {e}")


def read_logs(
    filepath: str = "trading/bots/ai_bot/logs/ai_bot.log",
    level: Optional[str] = None,
    module: Optional[str] = None,
    limit: int = 100
) -> List[Dict[str, Any]]:
    """
    Lit les logs depuis un fichier.
    
    Args:
        filepath: Chemin du fichier de logs.
        level: Niveau de log.
        module: Module.
        limit: Nombre maximum de logs.
        
    Returns:
        Liste des logs.
    """
    logs = []
    
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            for line in f:
                try:
                    log = json.loads(line.strip())
                    logs.append(log)
                except json.JSONDecodeError:
                    continue
        
        # Filtrage
        if level:
            logs = [l for l in logs if l.get('level') == level]
        
        if module:
            logs = [l for l in logs if l.get('module') == module]
        
        # Tri par timestamp (plus récent en premier)
        logs.sort(key=lambda x: x.get('timestamp', ''), reverse=True)
        
        return logs[:limit]
        
    except FileNotFoundError:
        print(f"⚠️ Fichier de logs non trouvé: {filepath}")
        return []
    except Exception as e:
        print(f"❌ Erreur de lecture des logs: {e}")
        return []


def get_log_stats(
    filepath: str = "trading/bots/ai_bot/logs/ai_bot.log"
) -> Dict[str, Any]:
    """
    Retourne les statistiques des logs.
    
    Args:
        filepath: Chemin du fichier de logs.
        
    Returns:
        Statistiques des logs.
    """
    logs = read_logs(filepath, limit=10000)
    
    if not logs:
        return {'total': 0}
    
    levels = {}
    modules = {}
    
    for log in logs:
        level = log.get('level', 'UNKNOWN')
        module = log.get('module', 'UNKNOWN')
        levels[level] = levels.get(level, 0) + 1
        modules[module] = modules.get(module, 0) + 1
    
    return {
        'total': len(logs),
        'levels': levels,
        'modules': modules,
        'first_log': logs[-1].get('timestamp') if logs else None,
        'last_log': logs[0].get('timestamp') if logs else None
    }


