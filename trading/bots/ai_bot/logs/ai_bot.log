__all__ = [
    'EXAMPLE_LOGS',
    'write_example_logs',
    'read_logs',
    'get_log_stats'
]

# ============================================================
# EXÉCUTION (si fichier exécuté directement)
# ============================================================

if __name__ == "__main__":
    # Écriture des logs d'exemple
    write_example_logs()
    
    # Lecture et affichage des 5 derniers logs
    print("\n📋 Derniers logs:")
    logs = read_logs(limit=5)
    for log in logs:
        print(f"[{log.get('timestamp')}] {log.get('level')} - {log.get('message')}")
    
    # Statistiques
    print("\n📊 Statistiques:")
    stats = get_log_stats()
    print(f"Total logs: {stats.get('total', 0)}")
    print(f"Niveaux: {stats.get('levels', {})}")
    print(f"Modules: {stats.get('modules', {})}")

