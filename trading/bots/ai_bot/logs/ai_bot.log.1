    logs = read_logs(limit=5)
    for log in logs:
        print(f"[{log.get('timestamp')}] {log.get('level')} - {log.get('message')}")
    
    # Statistiques
    print("\n📊 Statistiques (rotation 1):")
    stats = get_log_stats()
    print(f"Total logs: {stats.get('total', 0)}")
    print(f"Niveaux: {stats.get('levels', {})}")
    print(f"Modules: {stats.get('modules', {})}")
    
    # Comparaison avec le fichier principal
    print("\n📊 Comparaison avec ai_bot.log:")
    try:
        comparison = compare_logs()
        print(f"Différence de logs: {comparison['comparison']['total_diff']}")
        print(f"Différence de niveaux: {comparison['comparison']['levels_diff']}")
    except Exception as e:
        print(f"Erreur de comparaison: {e}")

