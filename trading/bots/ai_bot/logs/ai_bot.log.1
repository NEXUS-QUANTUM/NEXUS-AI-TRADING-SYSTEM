# FONCTIONS DE GESTION DES LOGS
# ============================================================

def write_example_logs(filepath: str = "trading/bots/ai_bot/logs/ai_bot.log.1") -> None:
    """
    Écrit les logs d'exemple dans un fichier.
    
    Args:
        filepath: Chemin du fichier de logs.
    """
    import os
    
    try:
        # Création du répertoire si nécessaire
        os.makedirs(os.path.dirname(filepath), exist_ok=True)
        
        with open(filepath, 'w', encoding='utf-8') as f:
            for log in EXAMPLE_LOGS:
                f.write(json.dumps(log) + '\n')
        
        print(f"✅ Logs écrits dans {filepath}")
        
    except Exception as e:
        print(f"❌ Erreur d'écriture des logs: {e}")


def read_logs(
    filepath: str = "trading/bots/ai_bot/logs/ai_bot.log.1",
    level: Optional[str] = None,
    module: Optional[str] = None,
    limit: int = 100
) -> List[Dict[str, Any]]:
    """
    Lit les logs depuis un fichier.
    
    Args:
        filepath: Chemin du fichier de logs.
        level: Niveau de log.
        module: Module.
        limit: Nombre maximum de logs.
        
    Returns:
        Liste des logs.
    """
    logs = []
    
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            for line in f:
                try:
                    log = json.loads(line.strip())
                    logs.append(log)
                except json.JSONDecodeError:
                    continue
        
        # Filtrage
        if level:
            logs = [l for l in logs if l.get('level') == level]
        
        if module:
            logs = [l for l in logs if l.get('module') == module]
        
        # Tri par timestamp (plus récent en premier)
        logs.sort(key=lambda x: x.get('timestamp', ''), reverse=True)
        
        return logs[:limit]
        
    except FileNotFoundError:
        print(f"⚠️ Fichier de logs non trouvé: {filepath}")
        return []
    except Exception as e:
        print(f"❌ Erreur de lecture des logs: {e}")
        return []


def get_log_stats(
    filepath: str = "trading/bots/ai_bot/logs/ai_bot.log.1"
) -> Dict[str, Any]:
    """
    Retourne les statistiques des logs.
    
    Args:
        filepath: Chemin du fichier de logs.
        
    Returns:
        Statistiques des logs.
    """
    logs = read_logs(filepath, limit=10000)
    
    if not logs:
        return {'total': 0}
    
    levels = {}
    modules = {}
    
    for log in logs:
        level = log.get('level', 'UNKNOWN')
        module = log.get('module', 'UNKNOWN')
        levels[level] = levels.get(level, 0) + 1
        modules[module] = modules.get(module, 0) + 1
    
    return {
        'total': len(logs),
        'levels': levels,
        'modules': modules,
        'first_log': logs[-1].get('timestamp') if logs else None,
        'last_log': logs[0].get('timestamp') if logs else None
    }


def compare_logs(
    filepath1: str = "trading/bots/ai_bot/logs/ai_bot.log",
    filepath2: str = "trading/bots/ai_bot/logs/ai_bot.log.1"
) -> Dict[str, Any]:
    """
    Compare deux fichiers de logs.
    
    Args:
        filepath1: Premier fichier de logs.
        filepath2: Deuxième fichier de logs.
        
    Returns:
        Résultats de la comparaison.
    """
    stats1 = get_log_stats(filepath1)
    stats2 = get_log_stats(filepath2)
    
    return {
        'file1': {
            'path': filepath1,
            'stats': stats1
        },
        'file2': {
            'path': filepath2,
            'stats': stats2
        },
        'comparison': {
            'total_diff': stats2.get('total', 0) - stats1.get('total', 0),
            'levels_diff': {
                k: stats2.get('levels', {}).get(k, 0) - stats1.get('levels', {}).get(k, 0)
                for k in set(stats1.get('levels', {}).keys()) | set(stats2.get('levels', {}).keys())
            }
        }
    }


