# ============================================================
# FONCTION DE CRÉATION D'ARCHIVE
# ============================================================

def create_archive_file(filepath: str) -> None:
    """
    Crée un fichier d'archive avec les logs d'exemple.
    
    Args:
        filepath: Chemin du fichier d'archive.
    """
    try:
        # Création du répertoire si nécessaire
        import os
        os.makedirs(os.path.dirname(filepath), exist_ok=True)
        
        with gzip.open(filepath, 'wt', encoding='utf-8') as f:
            for log in EXAMPLE_LOGS:
                f.write(json.dumps(log) + '\n')
        
        logger.info(f"Fichier d'archive créé: {filepath}")
        
    except Exception as e:
        logger.error(f"Erreur de création de l'archive: {e}")


