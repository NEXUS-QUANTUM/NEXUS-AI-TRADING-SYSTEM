import gzip
import json
import logging
from datetime import datetime, timedelta
from typing import Dict, List, Any, Optional
import io

# Configuration du logging
logger = logging.getLogger(__name__)


class ArchiveLogEntry:
    """
    Structure d'une entrée de log archivée.
    """
    
    def __init__(
        self,
        timestamp: datetime,
        level: str,
        module: str,
        message: str,
        data: Optional[Dict[str, Any]] = None
    ):
        self.timestamp = timestamp
        self.level = level
        self.module = module
        self.message = message
        self.data = data or {}
    
    def to_dict(self) -> Dict[str, Any]:
        """Convertit en dictionnaire."""
        return {
            'timestamp': self.timestamp.isoformat(),
            'level': self.level,
            'module': self.module,
            'message': self.message,
            'data': self.data
        }
    
    @classmethod
    def from_dict(cls, data: Dict[str, Any]) -> 'ArchiveLogEntry':
        """Crée une entrée à partir d'un dictionnaire."""
        return cls(
            timestamp=datetime.fromisoformat(data['timestamp']),
            level=data['level'],
            module=data['module'],
            message=data['message'],
            data=data.get('data', {})
        )


class ArchiveLogReader:
    """
    Lecteur de logs archivés.
    """
    
    def __init__(self, archive_path: str = "trading/bots/ai_bot/logs/archive/archive.log.2026-01-01.gz"):
        """
        Initialise le lecteur de logs archivés.
        
        Args:
            archive_path: Chemin du fichier d'archive.
        """
        self.archive_path = archive_path
        self._entries: List[ArchiveLogEntry] = []
        self._loaded = False
    
    def load(self) -> None:
        """
        Charge les logs depuis l'archive.
        """
        if self._loaded:
            return
        
        try:
            with gzip.open(self.archive_path, 'rt', encoding='utf-8') as f:
                for line in f:
                    try:
                        data = json.loads(line.strip())
                        entry = ArchiveLogEntry.from_dict(data)
                        self._entries.append(entry)
                    except json.JSONDecodeError:
                        # Ignorer les lignes non-JSON
                        continue
            
            self._loaded = True
            logger.info(f"Logs archivés chargés: {len(self._entries)} entrées")
            
        except FileNotFoundError:
            logger.warning(f"Fichier d'archive non trouvé: {self.archive_path}")
            self._entries = []
            self._loaded = True
        except Exception as e:
            logger.error(f"Erreur de chargement de l'archive: {e}")
            self._entries = []
            self._loaded = True
    
    def get_entries(
        self,
        level: Optional[str] = None,
        module: Optional[str] = None,
        start_date: Optional[datetime] = None,
        end_date: Optional[datetime] = None,
        limit: int = 100
    ) -> List[ArchiveLogEntry]:
        """
        Récupère les entrées de log.
        
        Args:
            level: Niveau de log.
            module: Module.
            start_date: Date de début.
            end_date: Date de fin.
            limit: Nombre maximum d'entrées.
            
        Returns:
            Liste des entrées.
        """
        if not self._loaded:
            self.load()
        
        entries = self._entries.copy()
        
        # Filtrage
        if level:
            entries = [e for e in entries if e.level == level]
        
        if module:
            entries = [e for e in entries if e.module == module]
        
        if start_date:
            entries = [e for e in entries if e.timestamp >= start_date]
        
        if end_date:
            entries = [e for e in entries if e.timestamp <= end_date]
        
        # Tri par timestamp (plus récent en premier)
        entries.sort(key=lambda x: x.timestamp, reverse=True)
        
        return entries[:limit]
    
    def get_stats(self) -> Dict[str, Any]:
        """
        Retourne les statistiques des logs.
        
        Returns:
            Statistiques.
        """
        if not self._loaded:
            self.load()
        
        if not self._entries:
            return {'total': 0}
        
        levels = {}
        modules = {}
        
        for entry in self._entries:
            levels[entry.level] = levels.get(entry.level, 0) + 1
            modules[entry.module] = modules.get(entry.module, 0) + 1
        
        return {
            'total': len(self._entries),
            'levels': levels,
            'modules': modules,
            'first_entry': self._entries[-1].timestamp.isoformat() if self._entries else None,
            'last_entry': self._entries[0].timestamp.isoformat() if self._entries else None
        }


