def write_example_trades(filepath: str = "trading/bots/ai_bot/logs/trades.log") -> None:
    """
    Écrit les trades d'exemple dans un fichier.
    
    Args:
        filepath: Chemin du fichier de trades.
    """
    import os
    
    try:
        # Création du répertoire si nécessaire
        os.makedirs(os.path.dirname(filepath), exist_ok=True)
        
        with open(filepath, 'w', encoding='utf-8') as f:
            for trade in EXAMPLE_TRADES:
                f.write(json.dumps(trade) + '\n')
        
        print(f"✅ Trades écrits dans {filepath}")
        
    except Exception as e:
        print(f"❌ Erreur d'écriture: {e}")


def read_trades(
    filepath: str = "trading/bots/ai_bot/logs/trades.log",
    status: Optional[str] = None,
    symbol: Optional[str] = None,
    strategy: Optional[str] = None,
    start_time: Optional[datetime] = None,
    end_time: Optional[datetime] = None,
    min_pnl: Optional[float] = None,
    max_pnl: Optional[float] = None,
    limit: int = 100
) -> List[Dict[str, Any]]:
    """
    Lit les trades depuis un fichier.
    
    Args:
        filepath: Chemin du fichier de trades.
        status: Statut du trade.
        symbol: Symbole.
        strategy: Stratégie.
        start_time: Heure de début.
        end_time: Heure de fin.
        min_pnl: PNL minimum.
        max_pnl: PNL maximum.
        limit: Nombre maximum de trades.
        
    Returns:
        Liste des trades.
    """
    trades = []
    
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            for line in f:
                try:
                    trade = json.loads(line.strip())
                    trades.append(trade)
                except json.JSONDecodeError:
                    continue
        
        # Filtrage
        if status:
            trades = [t for t in trades if t.get('status') == status]
        
        if symbol:
            trades = [t for t in trades if t.get('symbol') == symbol]
        
        if strategy:
            trades = [t for t in trades if t.get('strategy') == strategy]
        
        if start_time:
            trades = [t for t in trades if datetime.fromisoformat(t.get('timestamp', '')) >= start_time]
        
        if end_time:
            trades = [t for t in trades if datetime.fromisoformat(t.get('timestamp', '')) <= end_time]
        
        if min_pnl is not None:
            trades = [t for t in trades if t.get('pnl', 0) >= min_pnl]
        
        if max_pnl is not None:
            trades = [t for t in trades if t.get('pnl', 0) <= max_pnl]
        
        # Tri par timestamp (plus récent en premier)
        trades.sort(key=lambda x: x.get('timestamp', ''), reverse=True)
        
        return trades[:limit]
        
    except FileNotFoundError:
        print(f"⚠️ Fichier de trades non trouvé: {filepath}")
        return []
    except Exception as e:
        print(f"❌ Erreur de lecture: {e}")
        return []


def get_trade_stats(
    filepath: str = "trading/bots/ai_bot/logs/trades.log"
) -> Dict[str, Any]:
    """
    Retourne les statistiques des trades.
    
    Args:
        filepath: Chemin du fichier de trades.
        
    Returns:
        Statistiques des trades.
    """
    trades = read_trades(filepath, limit=10000)
    
    if not trades:
        return {'total': 0}
    
    stats = {
        'total': len(trades),
        'by_status': {},
        'by_side': {},
        'by_type': {},
        'by_strategy': {},
        'by_symbol': {},
        'performance': {
            'total_pnl': 0,
            'total_commission': 0,
            'winning_trades': 0,
            'losing_trades': 0,
            'win_rate': 0.0,
            'avg_win': 0.0,
            'avg_loss': 0.0,
            'profit_factor': 0.0,
            'best_trade': 0,
            'worst_trade': 0
        },
        'first_trade': trades[-1].get('timestamp') if trades else None,
        'last_trade': trades[0].get('timestamp') if trades else None
    }
    
    winning_pnls = []
    losing_pnls = []
    
    for trade in trades:
        status = trade.get('status', 'UNKNOWN')
        side = trade.get('side', 'UNKNOWN')
        trade_type = trade.get('type', 'UNKNOWN')
        strategy = trade.get('strategy', 'UNKNOWN')
        symbol = trade.get('symbol', 'UNKNOWN')
        pnl = trade.get('pnl', 0)
        commission = trade.get('commission', 0)
        
        stats['by_status'][status] = stats['by_status'].get(status, 0) + 1
        stats['by_side'][side] = stats['by_side'].get(side, 0) + 1
        stats['by_type'][trade_type] = stats['by_type'].get(trade_type, 0) + 1
        stats['by_strategy'][strategy] = stats['by_strategy'].get(strategy, 0) + 1
        stats['by_symbol'][symbol] = stats['by_symbol'].get(symbol, 0) + 1
        
        stats['performance']['total_pnl'] += pnl
        stats['performance']['total_commission'] += commission
        
        if status == 'CLOSED' or status == 'PARTIALLY_CLOSED':
            if pnl > 0:
                stats['performance']['winning_trades'] += 1
                winning_pnls.append(pnl)
                if pnl > stats['performance']['best_trade']:
                    stats['performance']['best_trade'] = pnl
            elif pnl < 0:
                stats['performance']['losing_trades'] += 1
                losing_pnls.append(pnl)
                if pnl < stats['performance']['worst_trade']:
                    stats['performance']['worst_trade'] = pnl
    
    total_closed = stats['performance']['winning_trades'] + stats['performance']['losing_trades']
    if total_closed > 0:
        stats['performance']['win_rate'] = stats['performance']['winning_trades'] / total_closed
        
        if winning_pnls:
            stats['performance']['avg_win'] = sum(winning_pnls) / len(winning_pnls)
        if losing_pnls:
            stats['performance']['avg_loss'] = sum(losing_pnls) / len(losing_pnls)
        
        total_win = sum(winning_pnls) if winning_pnls else 0
        total_loss = abs(sum(losing_pnls)) if losing_pnls else 0
        stats['performance']['profit_factor'] = total_win / total_loss if total_loss > 0 else float('inf')
    
    return stats


def get_trades_by_period(
    filepath: str = "trading/bots/ai_bot/logs/trades.log",
    period: str = "day"
) -> Dict[str, List[Dict[str, Any]]]:
    """
    Groupe les trades par période.
    
    Args:
        filepath: Chemin du fichier de trades.
        period: Période ('day', 'hour').
        
    Returns:
        Dictionnaire des trades groupés par période.
    """
    trades = read_trades(filepath, limit=10000)
    
    grouped = {}
    
    for trade in trades:
        timestamp = trade.get('timestamp', '')
        if period == 'day':
            key = timestamp[:10]  # YYYY-MM-DD
        else:
            key = timestamp[:13]  # YYYY-MM-DDTHH
        
        if key not in grouped:
            grouped[key] = []
        grouped[key].append(trade)
    
    return grouped


def get_trade_performance_by_strategy(
    filepath: str = "trading/bots/ai_bot/logs/trades.log"
) -> Dict[str, Dict[str, Any]]:
    """
    Retourne la performance par stratégie.
    
    Args:
        filepath: Chemin du fichier de trades.
        
    Returns:
        Performance par stratégie.
    """
    trades = read_trades(filepath, limit=10000)
    
    performance = {}
    
    for trade in trades:
        strategy = trade.get('strategy', 'UNKNOWN')
        pnl = trade.get('pnl', 0)
        status = trade.get('status', 'UNKNOWN')
        
        if strategy not in performance:
            performance[strategy] = {
                'total_trades': 0,
                'winning_trades': 0,
                'losing_trades': 0,
                'total_pnl': 0,
                'win_rate': 0.0,
                'avg_pnl': 0.0
            }
        
        performance[strategy]['total_trades'] += 1
        performance[strategy]['total_pnl'] += pnl
        
        if status == 'CLOSED' or status == 'PARTIALLY_CLOSED':
            if pnl > 0:
                performance[strategy]['winning_trades'] += 1
            elif pnl < 0:
                performance[strategy]['losing_trades'] += 1
    
    # Calcul des métriques
    for strategy, data in performance.items():
        total = data['total_trades']
        if total > 0:
            data['avg_pnl'] = data['total_pnl'] / total
        
        closed = data['winning_trades'] + data['losing_trades']
        if closed > 0:
            data['win_rate'] = data['winning_trades'] / closed
    
    return performance


