class TradeStatus(Enum):
    """Statuts des trades."""
    OPEN = "open"
    CLOSED = "closed"
    PARTIALLY_CLOSED = "partially_closed"
    CANCELLED = "cancelled"
    EXPIRED = "expired"


class TradeSide(Enum):
    """Côté des trades."""
    BUY = "buy"
    SELL = "sell"


class TradeType(Enum):
    """Types de trades."""
    MARKET = "market"
    LIMIT = "limit"
    STOP = "stop"
    STOP_LIMIT = "stop_limit"


