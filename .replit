{
  "name": "NEXUS AI TRADING SYSTEM",
  "description": "Plateforme IA de trading algorithmique universelle, autonome, modulaire et professionnelle",
  "author": "NEXUS QUANTUM LTD",
  "version": "1.0.0",
  "copyright": "Copyright © 2026 NEXUS QUANTUM LTD",
  "ceo": "Dr X... - Majority Shareholder",
  "language": "python",
  "run": "python backend/main.py",
  "entrypoint": "backend/main.py",
  "environment": "poetry",
  "packager": "pip",
  "nix": {
    "packages": [
      "python311",
      "python311Packages.pip",
      "python311Packages.poetry",
      "nodejs_20",
      "yarn",
      "docker",
      "docker-compose",
      "postgresql",
      "redis",
      "git",
      "curl",
      "wget",
      "openssl",
      "gcc",
      "g++",
      "make",
      "cmake",
      "pkg-config",
      "openssl.dev",
      "zlib.dev",
      "libffi.dev",
      "libxml2.dev",
      "libxslt.dev",
      "postgresql.dev",
      "redis.dev"
    ]
  },
  "shell": {
    "command": "/bin/bash",
    "env": {
      "PYTHONPATH": "${PYTHONPATH}:${REPLIT_ROOT}",
      "PYTHONUNBUFFERED": "1",
      "NODE_ENV": "development",
      "NEXT_PUBLIC_APP_URL": "https://${REPL_SLUG}.${REPL_OWNER}.repl.co",
      "NEXT_PUBLIC_API_URL": "https://${REPL_SLUG}.${REPL_OWNER}.repl.co/api/v1",
      "NEXT_PUBLIC_WEBSOCKET_URL": "wss://${REPL_SLUG}.${REPL_OWNER}.repl.co/ws",
      "DATABASE_URL": "postgresql://postgres:postgres@localhost:5432/nexus_ai",
      "REDIS_URL": "redis://localhost:6379/0"
    }
  },
  "compile": {
    "command": "pip install -r requirements.txt && pip install -r requirements-dev.txt",
    "triggerFiles": ["requirements.txt", "requirements-dev.txt", "pyproject.toml"]
  },
  "scripts": {
    "start": "python backend/main.py",
    "dev": "python backend/main.py --reload",
    "prod": "python backend/main.py --host 0.0.0.0 --port 8000 --workers 4",
    "test": "pytest",
    "test:coverage": "pytest --cov=backend --cov-report=html",
    "lint": "flake8 backend && black --check backend && isort --check-only backend",
    "format": "black backend && isort backend",
    "type-check": "mypy backend",
    "migrate": "alembic upgrade head",
    "migrate:make": "alembic revision --autogenerate",
    "docker:build": "docker-compose -f docker-compose.dev.yml build",
    "docker:up": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "docker:clean": "docker-compose -f docker-compose.dev.yml down -v --rmi all",
    "ai:train": "python ai/training/trainer.py",
    "ai:predict": "python ai/prediction/predictor.py",
    "backtest": "python trading/backtesting/backtest_engine.py",
    "seed": "python backend/database/seeders/main_seeder.py",
    "reset": "python backend/database/seeders/reset_db.py",
    "shell": "python -c 'import IPython; IPython.terminal.ipapp.launch_new_instance()'",
    "format:all": "prettier --write . && black . && isort .",
    "lint:all": "prettier --check . && flake8 . && black --check . && isort --check-only . && mypy .",
    "precommit": "yarn format:all && yarn lint:all && yarn test",
    "clean": "rm -rf .next dist build *.pyc __pycache__ node_modules .pytest_cache .mypy_cache .ruff_cache",
    "reset:db": "yarn docker:down && yarn docker:up && yarn migrate && yarn seed"
  },
  "env": [
    "APP_NAME",
    "APP_ENV",
    "APP_DEBUG",
    "APP_SECRET_KEY",
    "APP_TIMEZONE",
    "APP_SITE_NAME",
    "APP_SITE_DESCRIPTION",
    "APP_SITE_URL",
