    "devops": {
      "dependencies": {
        "docker": "7.1.0",
        "docker-compose": "1.0.0",
        "kubernetes": "31.0.0",
        "helm": "1.1.0",
        "terraform": "3.0.0"
      }
    }
  },
  "services": {
    "postgresql": {
      "type": "database",
      "image": "postgres:16-alpine",
      "environment": {
        "POSTGRES_USER": "nexus",
        "POSTGRES_PASSWORD": "nexus123",
        "POSTGRES_DB": "nexus_ai"
      },
      "ports": {
        "5432": 5432
      },
      "volumes": {
        "postgres_data": "/var/lib/postgresql/data"
      },
      "healthcheck": {
        "test": ["CMD-SHELL", "pg_isready -U nexus"],
        "interval": "10s",
        "timeout": "5s",
        "retries": 5
      }
    },
    "redis": {
      "type": "cache",
      "image": "redis:7-alpine",
      "ports": {
        "6379": 6379
      },
      "volumes": {
        "redis_data": "/data"
      },
      "healthcheck": {
        "test": ["CMD", "redis-cli", "ping"],
        "interval": "10s",
        "timeout": "5s",
        "retries": 5
      }
    },
    "postgres-ts": {
      "type": "database",
      "image": "timescale/timescaledb:2.17.2-pg16",
      "environment": {
        "POSTGRES_USER": "nexus",
        "POSTGRES_PASSWORD": "nexus123",
        "POSTGRES_DB": "nexus_ts"
      },
      "ports": {
        "5433": 5432
      },
      "volumes": {
        "timescaledb_data": "/var/lib/postgresql/data"
      }
    },
    "mongodb": {
      "type": "database",
      "image": "mongo:7",
      "environment": {
        "MONGO_INITDB_ROOT_USERNAME": "nexus",
        "MONGO_INITDB_ROOT_PASSWORD": "nexus123",
        "MONGO_INITDB_DATABASE": "nexus_ai"
      },
      "ports": {
        "27017": 27017
      },
      "volumes": {
        "mongodb_data": "/data/db"
      }
    },
    "prometheus": {
      "type": "monitoring",
      "image": "prom/prometheus:latest",
      "ports": {
        "9090": 9090
      },
      "volumes": {
        "prometheus_data": "/prometheus"
      },
      "config": {
        "scrape_interval": "15s",
        "evaluation_interval": "15s"
      }
    },
    "grafana": {
      "type": "monitoring",
      "image": "grafana/grafana:latest",
      "environment": {
        "GF_SECURITY_ADMIN_USER": "admin",
        "GF_SECURITY_ADMIN_PASSWORD": "admin",
        "GF_INSTALL_PLUGINS": "grafana-piechart-panel"
      },
      "ports": {
        "3001": 3000
      },
      "volumes": {
        "grafana_data": "/var/lib/grafana"
      }
    },
    "loki": {
      "type": "logging",
      "image": "grafana/loki:latest",
      "ports": {
        "3100": 3100
      },
      "volumes": {
        "loki_data": "/loki"
      }
    },
    "tempo": {
      "type": "tracing",
      "image": "grafana/tempo:latest",
      "ports": {
        "3200": 3200,
        "4317": 4317,
        "4318": 4318
      },
      "volumes": {
        "tempo_data": "/tempo"
      }
    },
    "nginx": {
      "type": "proxy",
      "image": "nginx:alpine",
      "ports": {
        "80": 80,
        "443": 443
      },
      "volumes": {
        "nginx_conf": "/etc/nginx/conf.d"
      }
    }
  },
  "workflows": {
    "test": {
      "steps": [
        "yarn install",
        "pip install -r requirements.txt",
        "pytest",
        "yarn test"
      ]
    },
    "deploy": {
      "steps": [
        "yarn install",
        "pip install -r requirements.txt",
        "yarn build",
        "docker-compose -f docker-compose.prod.yml up -d --build"
      ]
    },
    "backup": {
      "steps": [
        "docker exec postgres pg_dump -U nexus nexus_ai > backup.sql",
        "docker exec redis redis-cli SAVE",
        "tar -czf backup_$(date +%Y%m%d).tar.gz backup.sql"
      ]
    },
    "migration": {
      "steps": [
        "alembic revision --autogenerate",
        "alembic upgrade head"
      ]
    }
  }
}
