  "plugins": [
    {
      "name": "python",
      "enabled": true,
      "config": {
        "venv": "venv",
        "python": "python3",
        "pip": "pip"
      }
    },
    {
      "name": "nodejs",
      "enabled": true,
      "config": {
        "npm": "npm",
        "yarn": "yarn",
        "node": "node"
      }
    },
    {
      "name": "docker",
      "enabled": true,
      "config": {
        "compose": "docker-compose"
      }
    },
    {
      "name": "postgresql",
      "enabled": true,
      "config": {
        "version": "16",
        "port": 5432
      }
    },
    {
      "name": "redis",
      "enabled": true,
      "config": {
        "version": "7",
        "port": 6379
      }
    },
    {
      "name": "nginx",
      "enabled": true,
      "config": {
        "port": 80
      }
    },
    {
      "name": "prometheus",
      "enabled": true,
      "config": {
        "port": 9090
      }
    },
    {
      "name": "grafana",
      "enabled": true,
      "config": {
        "port": 3001
      }
    }
  ],
  "ports": [
    {
      "name": "Frontend",
      "port": 3000,
      "public": true,
      "protocol": "http",
      "description": "Next.js Dashboard"
    },
    {
      "name": "Backend API",
      "port": 8000,
      "public": true,
      "protocol": "http",
      "description": "FastAPI Backend"
    },
    {
      "name": "API Docs",
      "port": 8000,
      "path": "/docs",
      "public": true,
      "protocol": "http",
      "description": "Swagger API Documentation"
    },
    {
      "name": "Grafana",
      "port": 3001,
      "public": true,
      "protocol": "http",
      "description": "Monitoring Dashboard"
    },
    {
      "name": "Prometheus",
      "port": 9090,
      "public": true,
      "protocol": "http",
      "description": "Metrics Server"
    },
    {
      "name": "PostgreSQL",
      "port": 5432,
      "public": false,
      "protocol": "tcp",
      "description": "Primary Database"
    },
    {
      "name": "Redis",
      "port": 6379,
      "public": false,
      "protocol": "tcp",
      "description": "Cache & Queue"
    }
  ],
  "templates": {
    "frontend": {
      "path": "apps/web"
    },
    "backend": {
      "path": "backend"
    },
    "ai": {
      "path": "ai"
    },
    "trading": {
      "path": "trading"
    }
  },
  "modules": {
    "frontend": {
      "build": "cd apps/web && npm run build",
      "dev": "cd apps/web && npm run dev",
      "start": "cd apps/web && npm start"
    },
    "backend": {
      "build": "pip install -r requirements.txt",
      "dev": "python backend/main.py --reload",
      "start": "python backend/main.py"
    },
    "ai": {
      "train": "python ai/training/trainer.py",
      "predict": "python ai/prediction/predictor.py"
    },
    "trading": {
      "backtest": "python trading/backtesting/backtest_engine.py"
    }
  },
  "panels": {
    "frontend": {
      "name": "Frontend",
      "type": "webview",
      "url": "http://localhost:3000",
      "position": "left"
    },
    "backend": {
      "name": "Backend",
      "type": "terminal",
      "command": "python backend/main.py --reload",
      "position": "bottom"
    },
    "logs": {
      "name": "Logs",
      "type": "terminal",
      "command": "tail -f backend/logs/app.log",
      "position": "bottom"
    },
    "api": {
      "name": "API Docs",
      "type": "webview",
      "url": "http://localhost:8000/docs",
      "position": "right"
    },
    "monitoring": {
      "name": "Monitoring",
      "type": "webview",
      "url": "http://localhost:3001",
      "position": "right"
    },
    "db": {
      "name": "Database",
      "type": "terminal",
      "command": "psql postgresql://postgres:postgres@localhost:5432/nexus_ai",
      "position": "bottom"
    },
    "redis": {
      "name": "Redis",
      "type": "terminal",
      "command": "redis-cli",
      "position": "bottom"
    }
  },
  "secrets": [
    "APP_SECRET_KEY",
    "JWT_SECRET_KEY",
    "ENCRYPTION_KEY",
    "NEXUS_SECRET_KEY",
    "DATABASE_PASSWORD",
    "REDIS_PASSWORD",
    "BINANCE_API_KEY",
    "BINANCE_API_SECRET",
    "ALPACA_API_KEY",
    "ALPACA_API_SECRET",
    "BYBIT_API_KEY",
    "BYBIT_API_SECRET",
    "KRAKEN_API_KEY",
    "KRAKEN_API_SECRET",
    "COINBASE_API_KEY",
    "COINBASE_API_SECRET",
    "COINBASE_PASSPHRASE",
    "OANDA_API_KEY",
    "STRIPE_API_KEY",
    "STRIPE_PUBLISHABLE_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "PAYPAL_CLIENT_ID",
    "PAYPAL_CLIENT_SECRET",
    "OPENAI_API_KEY",
    "HUGGINGFACE_API_KEY",
    "LANGCHAIN_API_KEY",
    "SMTP_PASSWORD",
    "TELEGRAM_BOT_TOKEN",
    "SLACK_WEBHOOK_URL",
    "DISCORD_WEBHOOK_URL",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "SENTRY_DSN",
    "AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY",
    "GCP_CREDENTIALS_PATH",
    "AZURE_STORAGE_CONNECTION_STRING",
    "VAULT_TOKEN"
  ],
  "workspace": {
    "root": ".",
    "folders": [
      "ai",
      "apps",
      "backend",
      "blockchain",
      "configs",
      "data",
      "deployments",
      "docs",
      "infrastructure",
      "scripts",
      "security",
      "shared",
      "tests",
      "trading"
    ],
    "ignored": [
      ".git",
      ".next",
      "node_modules",
      "venv",
      "__pycache__",
      "*.pyc",
      "dist",
      "build",
      "out",
      ".idea",
      ".vscode"
    ]
  },
  "preview": {
    "port": 3000,
    "command": "npm run dev",
    "workingDir": "apps/web"
  },
  "packages": {
    "frontend": {
      "dependencies": {
