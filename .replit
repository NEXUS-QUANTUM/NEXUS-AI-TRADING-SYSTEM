    "trading": {
      "dependencies": {
        "ccxt": "4.4.37",
        "python-binance": "1.0.19",
        "alpaca-trade-api": "3.0.0",
        "oandapyV20": "3.0.4",
        "ib_insync": "0.9.86",
        "yfinance": "0.2.47",
